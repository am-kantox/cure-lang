# Comprehensive syntax fixture for the Vicure Vim / Neovim plugin.
# Every keyword bucket, lexical shape, operator, and container
# surface listed in `NEOVIM_PLUGIN.md` appears at least once so
# changes to `syntax/cure.vim` can be spot-checked visually.

### Fenced doc comment (Cure v0.17+).
@since v0.28.0
@author Vicure
###

mod Comprehensive.Showcase
  # -------------------------------------------------------------------------
  # Imports
  # -------------------------------------------------------------------------

  use Std.List
  use Std.Io as Io
  use Std.Regex
  use Std.String

  # -------------------------------------------------------------------------
  # Records (simple and parameterised)
  # -------------------------------------------------------------------------

  rec Point
    x: Int
    y: Int

  rec Pair(A, B)
    first: A
    second: B

  # -------------------------------------------------------------------------
  # Type aliases and ADTs (including multi-line / guarded / refined forms)
  # -------------------------------------------------------------------------

  type UserId = Int

  type Result(T, E) =
    | Ok(T)
    | Error(E)

  type NonNeg = {n: Int | n >= 0}

  # -------------------------------------------------------------------------
  # Protocols and implementations (the modern typeclass surface)
  # -------------------------------------------------------------------------

  proto Show(T)
    fn show(x: T) -> String

  proto Eqish(T)
    fn eqish?(a: T, b: T) -> Bool

  impl Show for Int
    fn show(x: Int) -> String = Std.String.from_int(x)

  impl Show for Point
    fn show(p: Point) -> String = "Point(#{p.x}, #{p.y})"

  impl Show for String
    fn show(s: String) -> String = s

  # -------------------------------------------------------------------------
  # Function definitions: literals, guards, destructuring, recursion
  # -------------------------------------------------------------------------

  fn simple(x: Int, y: Int) -> Int = x + y

  fn factorial(n: Nat) -> Nat =
    match n
      Zero     -> Succ(Zero)
      Succ(m)  -> n * factorial(m)

  fn classify(n: Int) -> Atom =
    match n
      m when m < 0 -> :negative
      0            -> :zero
      _            -> :positive

  fn apply_twice(f: (Int) -> Int, x: Int) -> Int =
    let g = fn(y) -> f(f(y)) end
    g(x)

  # -------------------------------------------------------------------------
  # Pattern matching on lists, options, results, tuples, and records
  # -------------------------------------------------------------------------

  fn first_or_zero(xs: List(Int)) -> Int =
    match xs
      []       -> 0
      [h | _t] -> h

  fn unwrap_or(opt: Option(Int), default: Int) -> Int =
    match opt
      Some(x) -> x
      None    -> default

  fn process(result: Result(Int, String)) -> String =
    match result
      Ok(value)  -> "Success: " <> Std.String.from_int(value)
      Error(msg) -> "Failed: " <> msg

  # -------------------------------------------------------------------------
  # Typed holes
  # -------------------------------------------------------------------------

  fn sketch(x: Int) -> Int = ?body_goes_here
  fn another()     -> Int = ??

  # -------------------------------------------------------------------------
  # Regex, char, and string literals
  # -------------------------------------------------------------------------

  fn digit_pattern() -> Any = ~r/^[0-9]+$/i
  fn word_pattern()  -> Any = ~r/\b\w+\b/

  fn letter_a()  -> Char = 'a'
  fn escape_n()  -> Char = '\n'
  fn erlang_a()  -> Char = ?a
  fn erlang_nl() -> Char = ?\n

  fn greeting(name: String) -> String =
    "Hello, #{name}! Welcome to Cure \uf00c."

  # -------------------------------------------------------------------------
  # Numeric literals, ranges, and operator zoo
  # -------------------------------------------------------------------------

  fn big_int()  -> Int   = 1_000_000_000
  fn hex()      -> Int   = 0xDEAD_BEEF
  fn binary()   -> Int   = 0b0100_1100
  fn fraction() -> Float = 3.141_592e-1

  fn operator_demo() -> Bool =
    let a = 1 + 2 * 3 / 4 - 5
    let b = 10 ** 3
    let c = a % 7
    let _ = 1..=10
    let _ = 1..5
    let _ = [1, 2, 3] ++ [4, 5]
    let _ = [1, 2, 3] -- [2]
    let _ = [1 | [2, 3]]
    let _ = Some(3) >>= fn(x) -> Some(x * 2) end
    let _ = fn(x) -> x + 1 end <$> Some(5)
    (a < b) && (b >= c || not true)

  # -------------------------------------------------------------------------
  # Tuple and map literal prefixes, record construction and update
  # -------------------------------------------------------------------------

  fn origin_tuple() -> Any = %[:point, 0, 0]
  fn defaults()     -> Any = %{greeting: "hi", idle_ms: 5_000}

  fn origin() -> Point = Point{x: 0, y: 0}

  fn translate(p: Point, dx: Int, dy: Int) -> Point =
    Point{p | x: p.x + dx, y: p.y + dy}

  # -------------------------------------------------------------------------
  # Concurrency surface: spawn / send / receive / after / Melquiades sigils
  # -------------------------------------------------------------------------

  fn start_worker() -> Pid = spawn(fn() -> :ok end)

  fn echo_loop() -> Unit =
    receive
      (:ping, from) -> send(from, :pong)
      (:quit, _)    -> :ok
    after 5_000
      :timeout

  fn melquiades_demo(target: Pid) -> Unit =
    target <-| :hello
    target  ✉ :world

  # -------------------------------------------------------------------------
  # Assertions and rewrites
  # -------------------------------------------------------------------------

  fn assert_positive(n: Int) -> Int =
    assert_type n > 0
    n

  fn rewrite_demo(xs: List(Int)) -> List(Int) =
    rewrite xs with
      | [a, b | rest] when a > b -> [b, a | rest]
      | other                    -> other

  # -------------------------------------------------------------------------
  # `with` chain and `try` / `catch` / `finally`
  # -------------------------------------------------------------------------

  fn fetch(name: String) -> Result(Int, String) =
    with
      Ok(raw)    <- load(name)
      Ok(parsed) <- parse(raw)
      Ok(parsed)
    else
      Error(reason) -> Error("fetch failed: " <> reason)

  fn guarded() -> Int =
    try
      dangerous_call()
    catch
      (:noproc, _) -> 0
      (:timeout, _) -> -1
    finally
      cleanup()

  fn load(_n: String)  -> Result(String, String) = Ok("42")
  fn parse(_s: String) -> Result(Int, String)    = Ok(42)
  fn dangerous_call()  -> Int                    = 0
  fn cleanup()         -> Unit                   = :ok

  fn main() -> Int = Io.println("=== Comprehensive syntax fixture ===")

# ---------------------------------------------------------------------------
# Container surface: FSM with recording, actor, supervisor, application.
# ---------------------------------------------------------------------------

## FSM with time-travel journal enabled. The `@record` decorator must
## be highlighted as an attribute and must not affect the indent of
## the `fsm` header below.
@record
fsm Exhibit
  Closed --open-->  Open
  Open   --close--> Closed
  Open   --sold-->  Sold

## Soft and hard event suffixes on FSM transitions.
fsm Gate
  Locked   --unlock?--> Open
  Open     --slam!-->   Locked

## Actor with pattern-matching `on_message` and an initial payload.
actor Painter with %[:idle, ""]
  on_start
    (state) -> state
  on_message
    (%[:submit, title], _state) -> %[:submitted, title]
    (:reset, _state)            -> %[:idle, ""]
    (:get, state)               -> notify(%[:painter_state, state])

## Supervision tree.
sup Gallery
  strategy  = :one_for_one
  intensity = 3
  period    = 5
  children
    Painter as painter
    Exhibit as exhibit (restart: :transient)

## OTP application container.
app Comprehensive
  vsn         = "0.1.0"
  description = "Vicure comprehensive fixture"
  root        = sup Gallery
  applications = [:logger, :runtime_tools]
  env         = %{greeting: "hi", idle_ms: 5_000}
  on_start
    (_kind, _args) -> :ok
  on_stop
    (_state) -> :ok
  on_phase :warm_cache
    (_args, _kind, _start_args) -> :ok

## Proof container: equality laws checked by the compiler.
proof Laws
  fn plus_zero(_n: Int) -> Eq(Int, n, n) = :cure_refl
  fn append_nil(_xs: List(T)) -> Eq(List(T), xs, xs) = :cure_refl
  fn map_id(_xs: List(T)) -> Eq(List(T), xs, xs) = :cure_refl
