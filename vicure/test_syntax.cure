# Quick tour of modern Cure (v0.28.x) syntax, intended for a
# visual spot-check of the Vicure Neovim / Vim plugin. Every major
# lexical shape and container surface is exercised at least once.

### Fenced doc comment.
Documents the `Showcase` module. `@since` tags are highlighted
inside fenced blocks as well as single-line `##` doc comments.
@since v0.28.0
###

mod Showcase
  use Std.List
  use Std.Io as Io
  use Std.Regex

  ## Records compile to BEAM maps with a `__struct__` discriminator.
  rec Point
    x: Int
    y: Int

  ## ADT with three constructors.
  type Shape =
    | Circle(Int)
    | Square(Int)
    | Triangle(Int, Int, Int)

  ## Protocol + implementation.
  proto Stringify(T)
    fn stringify(x: T) -> String

  impl Stringify for Int
    fn stringify(x: Int) -> String = Std.String.from_int(x)

  impl Stringify for Point
    fn stringify(p: Point) -> String = "Point(#{p.x}, #{p.y})"

  ## Pattern matching with guards, multi-clause, and wildcards.
  fn classify(n: Int) -> String =
    match n
      0                       -> "zero"
      m when m < 0            -> "negative"
      m when m > 0 && m < 10  -> "small"
      _                       -> "big"

  ## Numeric literals with `_` separators.
  fn constants() -> Int = 1_000_000
  fn kilobyte()  -> Int = 0b0100_0000_0000
  fn rgb_red()   -> Int = 0xFF_00_00
  fn pi_ish()    -> Float = 3.141_592

  ## Char literals come in two forms.
  fn letter_a() -> Char = 'a'
  fn newline()  -> Char = ?\n

  ## Regex literals.
  fn is_digit?(s: String) -> Bool =
    Std.Regex.is_match(~r/^[0-9]+$/, s)

  ## Typed holes let you sketch bodies.
  fn square_sketch(n: Int) -> Int = ?todo
  fn another_sketch() -> Int = ??

  ## String interpolation and `<>` concatenation.
  fn greet(name: String) -> String = "Hello, " <> name <> "!"

  ## Let bindings, the pipe operator, and higher-order functions.
  fn doubled_sum(xs: List(Int)) -> Int =
    let doubled = Std.List.map(xs, fn(x) -> x * 2 end)
    let evens   = Std.List.filter(doubled, fn(x) -> x % 2 == 0 end)
    Std.List.fold(evens, 0, fn(acc, x) -> acc + x end)

  ## Tuple and map literal prefixes.
  fn origin_tag() -> Any = %[:point, 0, 0]
  fn defaults()   -> Any = %{greeting: "hi", idle_ms: 5_000}

  ## Operator zoo: comparison, monadic sugar, ranges.
  fn operator_demo() -> Bool =
    let a = 1 + 2 * 3 / 4 - 5
    let b = 10 ** 3
    let c = 1..=10
    let d = [1, 2, 3] ++ [4, 5] ++ []
    let e = Some(3) >>= fn(x) -> Some(x * 2) end
    a < b && (b >= 100 || not false)

  ## Atoms with trailing `?`/`!`.
  fn status_probe() -> Atom =
    match :ok
      :ok       -> :ok!
      :retry    -> :retry?
      _         -> :unknown

  fn main() -> Int = Io.println("=== Vicure syntax tour ===")

## FSM with the v0.28 time-travel journal enabled. The `@record`
## decorator is highlighted as an attribute and must NOT count as a
## block opener: indentation below still aligns under `fsm`.
@record
fsm TrafficLight
  Red    --timer-->     Green
  Green  --timer-->     Yellow
  Yellow --timer-->     Red
  *      --emergency--> Red

## Actor with an initial payload and a session-typed mailbox.
actor Painter with %[:idle, ""]
  on_start
    (state) -> state
  on_message
    (%[:submit, title], _state) -> %[:submitted, title]
    (:reset, _state)            -> %[:idle, ""]
    (:get, state)               -> notify(%[:painter_state, state])

## Supervisor declaring typed children.
sup Gallery
  strategy  = :one_for_one
  intensity = 3
  period    = 5
  children
    Painter as painter
    TrafficLight as lights (restart: :transient)

## OTP application container.
app Showcase
  vsn         = "0.1.0"
  description = "Vicure syntax showcase"
  root        = sup Gallery
  on_start
    (_kind, _args) -> :ok
  on_stop
    (_state) -> :ok
  on_phase :warm_cache
    (_args, _kind, _start_args) -> :ok

## Propositional equality laws checked by the compiler.
proof Laws
  ## `n + 0 == n` for every integer.
  fn plus_zero(_n: Int) -> Eq(Int, n, n) = :cure_refl
  ## Appending the empty list is the identity.
  fn append_nil(_xs: List(T)) -> Eq(List(T), xs, xs) = :cure_refl
