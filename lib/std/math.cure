mod Std.Math
  ## Mathematical operations.
  ##
  ## A thin veneer over Erlang's `:math` and `:erlang` BIFs plus a
  ## handful of small integer helpers written in Cure. `Float`
  ## functions (`sqrt`, `pow`, `log`, ...) operate on IEEE-754
  ## doubles; integer helpers expect `Int`.
  ##
  ## ## Examples
  ##
  ## ```cure
  ## use Std.Math
  ##
  ## abs(0 - 5)                              # => 5
  ## sqrt(16.0)                              # => 4.0
  ## pow(2.0, 10.0)                          # => 1024.0
  ## clamp(42, 0, 10)                        # => 10
  ## is_even(8)                              # => true
  ## ```
  ##
  ## ```cure
  ## use Std.Math
  ##
  ## # Compute the length of the hypotenuse of a 3-4 right triangle.
  ## sqrt(pow(3.0, 2.0) + pow(4.0, 2.0))     # => 5.0
  ## ```

  ## Group tag consumed by `Cure.Stdlib.Preload`.
  fn __group__() -> Atom = :numeric

  ## Absolute value. Implemented as `:erlang.abs/1`.
  @extern(:erlang, :abs, 1)
  fn abs(x: Int) -> Int

  ## Square root; `:math.sqrt/1`.
  @extern(:math, :sqrt, 1)
  fn sqrt(x: Float) -> Float

  ## `base` raised to `exp`; `:math.pow/2`.
  @extern(:math, :pow, 2)
  fn pow(base: Float, exp: Float) -> Float

  ## Natural logarithm; `:math.log/1`.
  @extern(:math, :log, 1)
  fn log(x: Float) -> Float

  ## Base-2 logarithm; `:math.log2/1`.
  @extern(:math, :log2, 1)
  fn log2(x: Float) -> Float

  ## Base-10 logarithm; `:math.log10/1`.
  @extern(:math, :log10, 1)
  fn log10(x: Float) -> Float

  ## Smallest integer float >= `x`; `:math.ceil/1`.
  @extern(:math, :ceil, 1)
  fn ceil(x: Float) -> Float

  ## Greatest integer float <= `x`; `:math.floor/1`.
  @extern(:math, :floor, 1)
  fn floor(x: Float) -> Float

  ## Round a float to the nearest integer using banker's rounding.
  ## Implemented as `:erlang.round/1`.
  @extern(:erlang, :round, 1)
  fn round(x: Float) -> Int

  ## The mathematical constant pi; `:math.pi/0`.
  @extern(:math, :pi, 0)
  fn pi() -> Float

  ## Integer maximum.
  fn max(a: Int, b: Int) -> Int =
    pickup
      a >= b -> a
      else   -> b

  ## Integer minimum.
  fn min(a: Int, b: Int) -> Int =
    pickup
      a <= b -> a
      else   -> b

  ## Clamp `value` into the inclusive range `[lo, hi]`.
  fn clamp(value: Int, lo: Int, hi: Int) -> Int =
    pickup
      value < lo -> lo
      value > hi -> hi
      else       -> value

  ## Sign of `x`: `1` for positive, `0 - 1` for negative, `0` for zero.
  fn sign(x: Int) -> Int =
    pickup
      x > 0 -> 1
      x < 0 -> 0 - 1
      else  -> 0

  ## Additive inverse.
  fn negate(x: Int) -> Int = 0 - x

  ## `true` when `x` is even.
  fn is_even(x: Int) -> Bool = x % 2 == 0

  ## `true` when `x` is odd.
  fn is_odd(x: Int) -> Bool = x % 2 != 0

  ## Integer division that returns `0` on divide-by-zero instead of
  ## raising. Truncates toward zero otherwise.
  fn safe_div(a: Int, b: Int) -> Int =
    pickup
      b == 0 -> 0
      else   -> a / b
