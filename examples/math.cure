mod Math
  fn add(a: Int, b: Int) -> Int = a + b
  fn sub(a: Int, b: Int) -> Int = a - b
  fn mul(a: Int, b: Int) -> Int = a * b

  fn factorial(n: Int) -> Int
    | 0 -> 1
    | n -> n * factorial(n - 1)

  fn abs(x: Int) -> Int =
    pickup
      x > 0 -> x
      else  -> 0 - x

  fn max(a: Int, b: Int) -> Int =
    pickup
      a > b -> a
      else  -> b
