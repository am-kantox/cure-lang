mod PatternGuards
  # Multi-clause function with pattern matching
  fn describe(x: Int) -> String
    | 0 -> "zero"
    | 1 -> "one"
    | _ -> "other"

  # Function with guard
  fn abs(x: Int) -> Int when x >= 0 = x

  # Multi-clause with guards
  fn classify(x: Int) -> String
    | x when x > 0 -> "positive"
    | x when x < 0 -> "negative"
    | _ -> "zero"

  # Match expression
  fn result_to_string(r: Result(Int, String)) -> String =
    match r
      Ok(v) -> "ok"
      Error(e) -> "error"

  # List pattern matching
  fn head_or_zero(xs: List(Int)) -> Int =
    match xs
      [h | _] -> h
      [] -> 0

  # ---------------------------------------------------------------------------
  # Record patterns (v0.18.0)
  # ---------------------------------------------------------------------------

  rec Person
    name: String
    age: Int

  fn is_adult(p: Person) -> Bool =
    match p
      Person{age: a} when a >= 18 -> true
      _                           -> false

  # Field punning: `Person{name}` binds `name` to the `name` field.
  fn salute(p: Person) -> String =
    match p
      Person{name} -> "Hi " <> name

  # ---------------------------------------------------------------------------
  # Nested destructuring (v0.18.0)
  # ---------------------------------------------------------------------------

  fn unwrap_head_ok(xs: List(Result(Int, String)), default: Int) -> Int =
    match xs
      [Ok(v) | _] -> v
      _           -> default

  fn main() -> Int = 0
