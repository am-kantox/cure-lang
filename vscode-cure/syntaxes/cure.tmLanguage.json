{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.cure",
  "name": "Cure",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#atoms" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.cure",
          "match": "##.*$"
        },
        {
          "name": "comment.line.number-sign.cure",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.cure",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.cure", "match": "\\\\." },
        { "name": "meta.embedded.cure", "begin": "#\\{", "end": "\\}" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.cure", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.cure", "match": "\\b(0x[0-9a-fA-F]+|0b[01]+|\\d+)\\b" }
      ]
    },
    "atoms": {
      "name": "constant.other.symbol.cure",
      "match": ":[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cure",
          "match": "\\b(if|then|else|elif|match|return|throw|try|catch|finally|when|where|use|local|in|for)\\b"
        },
        {
          "name": "keyword.declaration.cure",
          "match": "\\b(fn|mod|rec|fsm|proto|impl|type|let|on_transition|on_enter|on_exit|on_failure|on_timer)\\b"
        },
        {
          "name": "constant.language.cure",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "types": {
      "name": "entity.name.type.cure",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cure",
          "match": "(?<=fn\\s+)[a-z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "name": "keyword.operator.cure",
      "match": "(\\->|\\|>|==|!=|<=|>=|<|>|\\+|\\-|\\*|/|%|\\.\\.=|\\.\\.|<>|=|\\?|!|\\|)"
    }
  }
}
