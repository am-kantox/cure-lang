{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.cure",
  "name": "Cure",
  "fileTypes": ["cure"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#char_literals" },
    { "include": "#holes" },
    { "include": "#attributes" },
    { "include": "#fsm_transition" },
    { "include": "#melquiades" },
    { "include": "#numbers" },
    { "include": "#atoms" },
    { "include": "#function_heads" },
    { "include": "#container_heads" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#builtin_types" },
    { "include": "#constructors" },
    { "include": "#module_paths" },
    { "include": "#types" },
    { "include": "#prefixes" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.cure",
          "begin": "###",
          "end": "###",
          "patterns": [
            { "include": "#doc_tags" },
            { "include": "#todo_markers" }
          ]
        },
        {
          "name": "comment.line.documentation.cure",
          "match": "##(?!#).*$",
          "captures": {
            "0": {
              "patterns": [
                { "include": "#doc_tags" },
                { "include": "#todo_markers" }
              ]
            }
          }
        },
        {
          "name": "comment.line.number-sign.cure",
          "match": "#(?!#).*$",
          "captures": {
            "0": {
              "patterns": [
                { "include": "#todo_markers" }
              ]
            }
          }
        }
      ]
    },
    "doc_tags": {
      "match": "@\\w+",
      "name": "storage.type.annotation.cure"
    },
    "todo_markers": {
      "match": "\\b(TODO|FIXME|NOTE|XXX|HACK|BUG)\\b",
      "name": "keyword.other.todo.cure"
    },
    "strings": {
      "name": "string.quoted.double.cure",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#string_escape" },
        { "include": "#string_interpolation" }
      ]
    },
    "string_escape": {
      "name": "constant.character.escape.cure",
      "match": "\\\\(u[0-9a-fA-F]{4}|[ntr\\\\\"'abfv0])"
    },
    "string_interpolation": {
      "name": "meta.embedded.line.cure",
      "begin": "#\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.cure" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.cure" }
      },
      "patterns": [
        { "include": "$self" }
      ]
    },
    "regex": {
      "name": "string.regexp.cure",
      "begin": "~r/",
      "end": "/[a-zA-Z]*",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.cure" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.cure" }
      },
      "patterns": [
        { "include": "#string_escape" }
      ]
    },
    "char_literals": {
      "patterns": [
        {
          "name": "string.quoted.single.cure",
          "match": "'(\\\\.|[^'\\\\])'"
        },
        {
          "name": "string.quoted.other.erlang.cure",
          "match": "\\?(\\\\[\\\\'\"ntrabfv0]|[[:print:]])"
        }
      ]
    },
    "holes": {
      "patterns": [
        {
          "name": "variable.other.constant.hole.cure",
          "match": "\\?\\?"
        },
        {
          "name": "variable.other.constant.hole.cure",
          "match": "\\?[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "attributes": {
      "name": "storage.modifier.attribute.cure",
      "match": "@[A-Za-z_][A-Za-z0-9_]*"
    },
    "fsm_transition": {
      "name": "keyword.control.transition.cure",
      "match": "--[A-Za-z_][A-Za-z0-9_]*[?!]?-->"
    },
    "melquiades": {
      "patterns": [
        {
          "name": "keyword.operator.send.melquiades.cure",
          "match": "<-\\|"
        },
        {
          "name": "keyword.operator.send.melquiades.cure",
          "match": "\u2709"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.binary.cure",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.hex.cure",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.float.cure",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.cure",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "atoms": {
      "name": "constant.other.symbol.cure",
      "match": ":[a-z_][a-zA-Z0-9_]*[?!]?"
    },
    "function_heads": {
      "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*[?!]?)",
      "captures": {
        "1": { "name": "storage.type.function.cure" },
        "2": { "name": "entity.name.function.cure" }
      }
    },
    "container_heads": {
      "patterns": [
        {
          "match": "\\b(mod)\\s+([A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "storage.type.module.cure" },
            "2": { "name": "entity.name.namespace.cure" }
          }
        },
        {
          "match": "\\b(rec)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.record.cure" },
            "2": { "name": "entity.name.type.record.cure" }
          }
        },
        {
          "match": "\\b(fsm)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.fsm.cure" },
            "2": { "name": "entity.name.type.fsm.cure" }
          }
        },
        {
          "match": "\\b(proto)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.protocol.cure" },
            "2": { "name": "entity.name.type.protocol.cure" }
          }
        },
        {
          "match": "\\b(impl)\\s+([A-Z][A-Za-z0-9_]*)(?:\\s+(for)\\s+([A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*))?",
          "captures": {
            "1": { "name": "storage.type.impl.cure" },
            "2": { "name": "entity.name.type.protocol.cure" },
            "3": { "name": "keyword.control.impl.for.cure" },
            "4": { "name": "entity.name.type.cure" }
          }
        },
        {
          "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.alias.cure" },
            "2": { "name": "entity.name.type.alias.cure" }
          }
        },
        {
          "match": "\\b(actor)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.actor.cure" },
            "2": { "name": "entity.name.type.actor.cure" }
          }
        },
        {
          "match": "\\b(sup)\\s+([A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "storage.type.supervisor.cure" },
            "2": { "name": "entity.name.type.supervisor.cure" }
          }
        },
        {
          "match": "\\b(app)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.application.cure" },
            "2": { "name": "entity.name.type.application.cure" }
          }
        },
        {
          "match": "\\b(proof)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.proof.cure" },
            "2": { "name": "entity.name.type.proof.cure" }
          }
        },
        {
          "match": "\\b(use)\\s+([A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)*)",
          "captures": {
            "1": { "name": "keyword.control.import.cure" },
            "2": { "name": "entity.name.namespace.cure" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cure",
          "match": "\\b(if|then|else|elif|match|when|where|for|in|do|of|end|with|try|catch|finally|throw|return|yield|assert_type|rewrite)\\b"
        },
        {
          "name": "storage.type.declaration.cure",
          "match": "\\b(fn|mod|rec|fsm|proto|impl|type|let|actor|sup|app|proof|local|use|as|extern)\\b"
        },
        {
          "name": "keyword.control.concurrency.cure",
          "match": "\\b(spawn|send|receive|after)\\b"
        },
        {
          "name": "storage.type.fsm.callback.cure",
          "match": "\\b(on_start|on_stop|on_transition|on_enter|on_exit|on_failure|on_timer|on_message|on_phase)\\b"
        },
        {
          "name": "keyword.operator.word.cure",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.boolean.cure",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.cure",
          "match": "\\bnil\\b"
        }
      ]
    },
    "builtin_types": {
      "name": "support.type.builtin.cure",
      "match": "\\b(Int|Float|Bool|String|Atom|Bitstring|Binary|Char|Any|Unit|Void|Nat|List|Tuple|Map|Set|Pair|Vector|Option|Result|Pid|Ref|Sigma|Pi|Eq|DPair)\\b"
    },
    "constructors": {
      "name": "support.class.constructor.cure",
      "match": "\\b(Ok|Error|Some|None|Zero|Succ|Pred|Self|refl)\\b"
    },
    "module_paths": {
      "name": "entity.name.namespace.cure",
      "match": "\\b[A-Z][A-Za-z0-9_]*(?:\\.[A-Z][A-Za-z0-9_]*)+\\b"
    },
    "types": {
      "name": "entity.name.type.cure",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.cure",
          "match": "-->|->|<-|=>|\\|>"
        },
        {
          "name": "keyword.operator.comparison.cure",
          "match": "==|!=|<=|>=|<>"
        },
        {
          "name": "keyword.operator.monadic.cure",
          "match": ">>=|>>|<\\*>|<\\*|\\*>|<\\$|\\$>"
        },
        {
          "name": "keyword.operator.assignment.compound.cure",
          "match": "\\+=|-=|\\*=|/="
        },
        {
          "name": "keyword.operator.range.cure",
          "match": "\\.\\.=|\\.\\."
        },
        {
          "name": "keyword.operator.cons.cure",
          "match": "::|\\+\\+|--|\\|\\||&&|\\*\\*"
        },
        {
          "name": "keyword.operator.arithmetic.cure",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.cure",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.cure",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.pipe.cure",
          "match": "\\|"
        }
      ]
    },
    "prefixes": {
      "patterns": [
        {
          "name": "punctuation.section.tuple.cure",
          "match": "%(?=\\[)"
        },
        {
          "name": "punctuation.section.map.cure",
          "match": "%(?=\\{)"
        }
      ]
    },
    "punctuation": {
      "name": "punctuation.separator.cure",
      "match": "[(),;]"
    }
  }
}
