# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
cure-*.tar

# Dialyzer PLT cache
/.dialyzer/*plt*

/.elixir-tools/
/.erl.history/

.tool-versions*

# Generated by `Mix.Tasks.Cure.BundleStdlib` on every compile: a
# mirror of `lib/std/*.cure` that makes the stdlib sources reachable
# via `:code.priv_dir(:cure)` at runtime (required by host consumers
# such as `:cure_site`). Regenerated deterministically; do not check in.
/priv/std/

# Generated by `Mix.Tasks.Cure.BundleStdlibBeams` on every compile: a
# compiled mirror of `lib/std/*.cure` that makes the stdlib BEAMs
# reachable via `:code.priv_dir(:cure)/ebin` at runtime (required by
# the REPL embedded in `:cure_site` and other host consumers to
# execute `Std.*.y` calls without `:undef`). Regenerated from sources
# and bundled into the hex tarball at pack time via `files:` in
# `mix.exs`; do not check in.
/priv/ebin/

# The main executable escript
/cure
